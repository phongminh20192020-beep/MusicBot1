# ─── Discord ─────────────────────────────────────────────────────────────
DISCORD_TOKEN=
CLIENT_ID=

# ─── Lavalink ────────────────────────────────────────────────────────────
LAVALINK_HOST=
LAVALINK_PORT=
LAVALINK_PASS=

# ─── Optional integrations (see README.md / RAILWAY.md) ──────────────────
YOUTUBE_REFRESH_TOKEN=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
STREAM_USER_TOKEN=

# ─── Web dashboard (see DASHBOARD.md) ─────────────────────────────────────
DASHBOARD_PASSWORD=
DASHBOARD_PORT=3000
LASTFM_API_KEY=your_lastfm_api_key

# ─── Proxy auto-refresh (see proxies.example.txt) ─────────────────────────
# Pulls + validates a fresh proxy list from ProxyScrape's free API and writes
# it to proxies.txt automatically, so /mv download always has working IPs to
# fall back to when YouTube blocks the server. One-off run: `npm run refresh-proxies`.
PROXY_AUTO_REFRESH=false
PROXY_REFRESH_INTERVAL_MS=1800000
PROXY_PROTOCOLS=http,socks5
PROXY_COUNTRY=all
PROXY_MAX=15
PROXY_TEST_TIMEOUT_MS=5000
PROXY_TEST_CONCURRENCY=40
